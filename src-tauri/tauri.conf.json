{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Novus Optra",
  "version": "0.1.5",
  "identifier": "com.vikra.apptauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Novus Optra",
        "width": 900,
        "height": 650,
        "center": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Novus Optra - Initializing",
        "width": 450,
        "height": 350,
        "center": true,
        "visible": true,
        "decorations": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0NzA4OTc0RThGRDRGQzgKUldUSVQvM29kSWx3TkVTRXZ5c2xqTjJKVk84M1NNaE1RRTR3SEt6RmV3TVBDOGdMQjI5M2FnYWQK",
      "endpoints": [
        "https://github.com/PrinceTyagia/novus-optra/releases/latest/download/latest.json"
      ]
    }
  }
}